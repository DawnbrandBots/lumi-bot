{
  "extends": "@tsconfig/node24/tsconfig.json",
  "include": ["src/**/*", "scripts/**/*", "test/**/*"],
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "resolveJsonModule": true,
    "sourceMap": true,
    "incremental": true,
    "noUncheckedIndexedAccess": true,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true
  }
}
