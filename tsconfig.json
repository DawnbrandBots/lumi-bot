{
  "extends": "@tsconfig/node24/tsconfig.json",
  "include": ["eslint.config.ts", "scripts/**/*", "src/**/*", "test/**/*"],
  "compilerOptions": {
    "noEmit": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "incremental": true,
    "noUncheckedIndexedAccess": true,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "allowJs": true
  }
}
