{
  "name": "lumi-bot",
  "version": "0.0.1",
  "repository": "https://github.com/DawnbrandBots/lumi-bot.git",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "postclean": "tsc --build --clean tsconfig.json tsconfig.build.json",
    "start": "node --enable-source-maps --env-file-if-exists=.env dist",
    "lint": "eslint --flag unstable_native_nodejs_ts_config .",
    "lint:fix": "eslint --flag unstable_native_nodejs_ts_config --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "register": "node --enable-source-maps --env-file-if-exists=.env scripts/registerCommands.ts",
    "bot:profile:update": "node --enable-source-maps --env-file-if-exists=.env scripts/updateBotProfile.ts",
    "db:recreate": "node --enable-source-maps --env-file-if-exists=.env scripts/recreateStaticDbs.ts",
    "db:migrate": "node --enable-source-maps --env-file-if-exists=.env scripts/migrateDbs.ts",
    "test:db": "node --enable-source-maps --env-file-if-exists=.env scripts/recreateDb.ts ./test/mikro-orm.test.config.ts",
    "test": "vitest"
  },
  "engines": {
    "node": ">=24",
    "yarn": "1.22.x"
  },
  "dependencies": {
    "@mikro-orm/core": "^7.1.4",
    "@mikro-orm/migrations": "^7.1.4",
    "@mikro-orm/sqlite": "^7.1.4",
    "debug": "^4.4.3",
    "discord.js": "~14.26.3",
    "fuse.js": "^7.4.2",
    "type-fest": "^5.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@mikro-orm/cli": "^7.1.4",
    "@tsconfig/node24": "^24.0.4",
    "@types/debug": "^4.1.13",
    "@types/node": "^26.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "3.8.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "optionalDependencies": {
    "bufferutil": "^4.1.0",
    "zlib-sync": "^0.1.10"
  },
  "mikro-orm": {
    "preferTs": true,
    "configPaths": [
      "./src/mikro-orm.config.ts"
    ]
  }
}
